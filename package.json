{
  "name": "msa-coffee-hands-on",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "scripts": {
    "monolith": "vite --config vite.monolith.mts",
    "msa": "concurrently -n catalog,order,gateway,frontend -c blue,green,yellow,magenta \"node microservices/catalog-service.mjs\" \"node microservices/order-service.mjs\" \"node microservices/gateway.mjs\" \"vite --config vite.msa.mts\"",
    "msa:catalog": "node microservices/catalog-service.mjs",
    "msa:order": "node microservices/order-service.mjs",
    "msa:gateway": "node microservices/gateway.mjs",
    "msa:frontend": "vite --config vite.msa.mts",
    "build": "vite build --config vite.build.mts",
    "deploy": "./scripts/deploy.sh",
    "deploy:infra": "./scripts/deploy-infra.sh",
    "cleanup": "./scripts/cleanup.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@use-funnel/react-router-dom": "^0.0.15",
    "es-toolkit": "^1.31.0",
    "framer-motion": "^12.23.24",
    "lottie-web": "^5.12.2",
    "overlay-kit": "^1.6.2",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^7.1.1",
    "tosslib": "file:./tosslib.tgz",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/vite-dev-server": "^0.18.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "concurrently": "^9.1.0",
    "hono": "^4.6.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.6"
  }
}
